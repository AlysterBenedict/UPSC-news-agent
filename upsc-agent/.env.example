# ============================================================
# UPSC Daily Digest — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# --- NVIDIA NIM API ---
NIM_API_KEY=nvapi-your-key-here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# --- Email (Gmail SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=benedictalyster@gmail.com
SMTP_PASS=your-gmail-app-password-here
EMAIL_FROM=benedictalyster@gmail.com
EMAIL_RECIPIENTS=sharonrishithas@gmail.com

# --- Paths ---
SCRAPER_OUTPUT_DIR=../zartifacts
OUTPUT_DIR=./output
DATA_DIR=./data

# --- Schedule (IST) ---
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
TIMEZONE=Asia/Kolkata

# --- Page Budget ---
MIN_PAGES=30
TARGET_PAGES=45
MAX_PAGES=70

# --- Processing ---
ANALYSIS_BATCH_SIZE=1
WRITER_BATCH_SIZE=10
LLM_DELAY_SECONDS=1.0
LLM_MAX_RETRIES=3
LLM_TIMEOUT=120

# --- Database ---
DB_PATH=./data/checkpoints.db
